{
  "name": "todo-ci-cd",
  "scripts": {
    "build": "npm ci --omit=dev",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:unit": "jest src/tests/unit",
    "test:coverage": "jest --coverage",
    "test:coverage:unit": "jest src/tests/unit --coverage",
    "ci": "npm run test:coverage:unit"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}